# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# --- Discord ---
# https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# --- LLM (DeepSeek R1 via Azure AI Foundry recommended) ---
# Works with any OpenAI-compatible endpoint: Azure, OpenAI, Groq, Together, etc.
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://your-resource.services.ai.azure.com/models
LLM_MODEL=DeepSeek-R1

# --- Backend ---
BACKEND_URL=http://localhost:8000
PORT=8000
LOG_LEVEL=INFO

# --- RAG ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50
